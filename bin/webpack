#!/usr/bin/env ruby

ENV["RAILS_ENV"] ||= ENV["RACK_ENV"] || "development"
ENV["NODE_ENV"]  ||= "development"

require "pathname"
ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../../Gemfile",
  Pathname.new(__FILE__).realpath)

require "bundler/setup"

# Ruby 3.3+ no longer auto-loads `logger`, but Webpacker (via ActiveSupport 6.1)
# references the `Logger` constant at load time before requiring it. This
# binstub boots on its own and does not load config/boot.rb, so require it here.
# REMOVE THIS WHEN YOU UPDATE TO RAILS 7.
require "logger"

require "webpacker"
require "webpacker/webpack_runner"

APP_ROOT = File.expand_path("..", __dir__)
Dir.chdir(APP_ROOT) do
  Webpacker::WebpackRunner.run(ARGV)
end
